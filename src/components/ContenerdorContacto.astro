---
const { plataforma, usuario } = Astro.props;
---
<a href={`https://www.${plataforma}.com/${usuario}`}>{plataforma}</a>

<style>
    a{
        padding: 2.5rem 2.5rem;
        background-color: #978F66;
        text-decoration: none;
        border-radius: 10px;
        color: white;
        font-size: 1.5rem;
    }

    a:hover{
        padding: 2.5rem 2.5rem;
        background-color: #978F66;
        text-decoration: none;
        border-radius: 10px;
        color: white;
        font-size: 2rem;
        transition: 1s;
    }
</style>
