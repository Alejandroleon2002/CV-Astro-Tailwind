---
const { plataforma, usuario, Icon } = Astro.props;
---

<a
    href={`https://www.${plataforma}.com/${usuario}`}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-3 rounded-[10px] bg-[#978F66] px-5 py-4 text-white no-underline text-2xl transition-transform duration-300 ease-in-out hover:translate-y-[-10px]"
>
    {Icon ? <Icon class="w-6 h-6 shrink-0 text-white stroke-current" /> : null}
    {plataforma}
</a>
