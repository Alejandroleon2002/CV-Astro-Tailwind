---
const { plataforma, usuario, Icon } = Astro.props;
---

<a
    href={`https://www.${plataforma}.com/${usuario}`}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2 text-sm px-3 py-2 sm:gap-3 sm:text-lg sm:px-5 sm:py-3 lg:text-2xl lg:py-4 rounded-[10px] bg-[#978F66] text-white no-underline transition-transform duration-300 ease-in-out hover:translate-y-[-10px]"
>
    {Icon ? <Icon class="w-6 h-6 shrink-0 text-white stroke-current" /> : null}
    {plataforma}
</a>
